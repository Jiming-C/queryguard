# Copy to .env.local and set ONE provider key. The app auto-detects which one
# you set. You don't need a paid key to run this.

# --- Free, no credit card (recommended) --------------------------------------
# Get a key at https://console.groq.com/keys (email/Google/GitHub, ~1 min).
GROQ_API_KEY=

# Other free options — set one of these instead of GROQ_API_KEY if you prefer:
# CEREBRAS_API_KEY=          # https://cloud.cerebras.ai  (no card; ~5 req/min)
# GEMINI_API_KEY=            # https://aistudio.google.com/apikey  (card required in EEA/UK/CH)
# OPENROUTER_API_KEY=        # https://openrouter.ai/keys  (must enable the privacy toggle)

# --- Paid Anthropic key (takes priority if set) ------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Overrides ---------------------------------------------------------------
# Pin a specific model for whichever provider is active (e.g. openai/gpt-oss-120b
# on Groq for stronger SQL).
# LLM_MODEL=

# Or point at any other OpenAI-compatible endpoint directly:
# LLM_BASE_URL=
# LLM_API_KEY=
